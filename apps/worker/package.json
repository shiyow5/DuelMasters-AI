{
  "name": "@dm-ai/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest:rules": "tsx src/jobs/ingest-rules.ts",
    "ingest:cards": "tsx src/jobs/ingest-cards.ts",
    "ingest:regulations": "tsx src/jobs/ingest-regulations.ts",
    "fix:card-types": "tsx src/jobs/fix-card-types.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dm-ai/core": "workspace:*",
    "@dm-ai/db": "workspace:*",
    "@dm-ai/rag": "workspace:*",
    "cheerio": "^1.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
