# Gemini
GEMINI_API_KEY=
# 任意: モデルチェーン上書き (カンマ区切り, 先頭から順に試しレート制限時に次へフォールバック)。
# 未設定なら既定 (チャット=無料の Gemma → 低コストの flash-lite / 構造化=Gemini 系のみ) を使う。
# GEMINI_CHAT_MODELS=gemma-4-31b-it,gemini-3.1-flash-lite
# GEMINI_STRUCTURED_MODELS=gemini-3.1-flash-lite,gemini-flash-latest
# エージェント(ツールループ)は別チェーン。flash-lite を主に(Gemma はツールループで収束しないため)。
# AGENT_CHAT_MODELS=gemini-3.1-flash-lite,gemma-4-31b-it

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# App
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
NODE_ENV=development

# 内部API認証 (Bot/管理操作 → API。ランダムな長い文字列を設定)
INTERNAL_API_KEY=

# Web クライアント用 Supabase (値は SUPABASE_URL / SUPABASE_ANON_KEY と同じ)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
