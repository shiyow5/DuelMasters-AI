{
  "name": "@dm-ai/agent",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "eval": "tsx eval/run.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dm-ai/core": "workspace:*",
    "@dm-ai/db": "workspace:*",
    "@dm-ai/deck-engine": "workspace:*",
    "@dm-ai/rag": "workspace:*",
    "@langchain/core": "^1.2.0",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/langgraph": "^1.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
